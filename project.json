{
  "langrev": "1",
  "warnings": [ "no-unused" ],
  // lib/ vendors gpu.c3l (pinned submodule) and sdl3.c3l; gpu.c3l's own lib/
  // provides the vk/vma/spvreflect bindings via the second search path.
  "dependency-search-paths": [ "lib", "lib/gpu.c3l/lib" ],
  "dependencies": [ "gpu", "vk", "vma", "spvreflect" ],
  "output": "build",
  "targets": {
    // Windowed: SDL3 window + swapchain, presents the textured triangle.
    // Run with --frames N for an auto-exit smoke, --no-vsync for MAILBOX.
    "hello_triangle_sdl": {
      "type": "executable",
      "dependencies": [ "sdl3" ],
      "sources": [ "hello_triangle_sdl/main.c3", "hello_triangle_sdl/shader_abi.c3", "shared/sample_window_sdl.c3", "shared/sample_args.c3", "shared/screenshot.c3", "shared/png.c3" ]
    },
    // Headless: no SDL. Proves the root-pointer compute ABI end to end.
    "root_pointer_compute": {
      "type": "executable",
      "sources": [ "root_pointer_compute/main.c3", "root_pointer_compute/shader_abi.c3" ]
    },
    // Headless rasterization: textured triangle to an offscreen target,
    // dumped as PPM. Proves graphics pipelines + heap from the fragment stage.
    "offscreen_triangle": {
      "type": "executable",
      "sources": [ "offscreen_triangle/main.c3", "offscreen_triangle/shader_abi.c3", "shared/sample_args.c3", "shared/screenshot.c3", "shared/png.c3" ]
    },
    // Headless: writes a pattern into a storage image by TextureIndex, then
    // samples it back by the same index. Proves the bindless descriptor heap.
    "bindless_texture_compute": {
      "type": "executable",
      "sources": [ "bindless_texture_compute/main.c3", "bindless_texture_compute/shader_abi.c3" ]
    },
    // Windowed: compute culls a quad grid and writes indirect draw args
    // (+ count where supported); one multi-draw renders via gl_DrawID.
    "textured_cube": {
      "type": "executable",
      "dependencies": [ "sdl3" ],
      "sources": [
        "textured_cube/main.c3", "textured_cube/shader_abi.c3",
        "shared/sample_window_sdl.c3", "shared/sample_args.c3",
        "shared/sample_camera.c3", "shared/screenshot.c3", "shared/png.c3"
      ]
    },
    "texture_filtering": {
      "type": "executable",
      "dependencies": [ "sdl3" ],
      "sources": [
        "texture_filtering/main.c3", "texture_filtering/shader_abi.c3",
        "shared/sample_window_sdl.c3", "shared/sample_args.c3",
        "shared/sample_camera.c3", "shared/screenshot.c3", "shared/png.c3"
      ]
    },
    "shared_selftest": {
      "type": "executable",
      "sources": [ "shared/selftest.c3", "shared/sample_args.c3", "shared/sample_camera.c3", "shared/png.c3" ]
    },
    "memory_report": {
      "type": "executable",
      "sources": [ "memory_report/main.c3" ]
    },
    "gpu_driven_draw_sdl": {
      "type": "executable",
      "dependencies": [ "sdl3" ],
      "sources": [ "gpu_driven_draw_sdl/main.c3", "gpu_driven_draw_sdl/shader_abi.c3", "shared/sample_window_sdl.c3", "shared/sample_args.c3", "shared/screenshot.c3", "shared/png.c3" ]
    }
  }
}
